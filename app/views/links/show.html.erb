<section class="link-thread">
  <header>
    <%= render @link %>

    <% if @link.description? %>
      <p>
        <%= @link.description %>
      </p>
    <% end %>
  </header>

  <% if logged_in? %>
    <div class="add-comment row">
      <div class="col-sm-6">
        <%= form_for [@link, @comment] do |f| %>
          <%= render "shared/errors", object: @comment %>

          <div class="form-group">
            <%= f.text_area :body, class: "form-control", placeholder: "The quick brown fox...", rows: 10, required: true %>
          </div>

          <div class="form-group">
            <%= f.button "add comment", class: "btn btn-success" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="all-comments row">
    <div class="col-sm-12">
      <% if @comments.present? %>
        <h3>Comments</h3>
      <% end %>

      <div class="infinite-scroll-stream" data-infinite-scroll>
        <div class="infinite-scroll-pages" data-infinite-scroll-target="pages">
          <%= render 'comments/page', comments: @comments, pagy: @pagy %>
        </div>
      </div>
    </div>
  </div>
</section>
